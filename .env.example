MARKET_DATA_MODE=simulated
STOCK_SYMBOLS=AAPL,MSFT,NVDA,AMZN,GOOGL,TSLA
ALPHA_VANTAGE_POLL_SECONDS=15

# Alpha Vantage API Configuration
ALPHA_VANTAGE_API_KEY=your_api_key_here

# PostgreSQL Configuration
POSTGRES_DB=market
POSTGRES_USER=market_user
POSTGRES_PASSWORD=your_secure_password_here

# Kafka Configuration
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC=stock_ticks

# Database Connection
DATABASE_URL=postgresql+psycopg2://market_user:your_secure_password_here@postgres:5432/market
